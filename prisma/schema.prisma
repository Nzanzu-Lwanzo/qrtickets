generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Ticket {
  id        Int      @id @default(autoincrement())
  code      String?  @unique
  qrCode    String?
  cloudID   String?
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
